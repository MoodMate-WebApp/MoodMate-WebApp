# ==========================================
# MoodMate - Environment Variables Setup
# ==========================================

# ------------------------------------------
# Backend Configuration (FastAPI)
# ------------------------------------------
# Supabase Project Connection
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# PostgreSQL Database Connection String (Direct access)
DATABASE_URL=postgresql://postgres:your_password@db.your_project.supabase.co:5432/postgres

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="MoodMate AI Engine"

# Security: CORS Allowed Origins
# For production, set this to your frontend URL (e.g., https://moodmate.vercel.app)
ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:5174", "http://localhost:3000"]

# ------------------------------------------
# Frontend Configuration (Vite)
# ------------------------------------------
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Backend API Endpoint
# Local development: http://localhost:8000
# Production: https://your-backend-api.hf.space
VITE_API_URL=http://localhost:8000
